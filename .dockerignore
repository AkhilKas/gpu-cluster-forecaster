# Keep the build context lean.
.git
.github
.venv
venv
**/__pycache__
**/*.pyc
**/*.pyo
**/.pytest_cache
**/.ruff_cache
**/.coverage
**/htmlcov
**/*.log

# Frontend build artifacts (we build inside the image)
frontend/node_modules
frontend/dist

# Data (we regenerate synthetic data during build)
data/raw/*
data/processed/*
backend/weights/*.pt
backend/weights/*.pth
backend/weights/*.onnx
backend/weights/*_metrics.json
backend/weights/*_history.json

# Editor + OS
.vscode
.idea
.DS_Store
